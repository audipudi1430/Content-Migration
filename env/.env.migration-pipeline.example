# Copy to env/.env.<yourstack> or merge into an existing env file.
# WordPress + Contentstack base vars are still required (see README).

# --- Source workbook (tabs = URL lists + one media tab) ---
MIGRATION_SOURCE_WORKBOOK=migration-source.xlsx
MIGRATION_MEDIA_TAB_NAME=media
# REST collection for tabs that do not have a per-tab override (see MIGRATION_SHEET_WP_REST_PATHS).
MIGRATION_WP_REST_PATH=/wp-json/wp/v2/posts
# Optional: per Excel tab name, WordPress REST base and Contentstack type (semicolon-separated sheet=value pairs).
# Tab names must match workbook sheet names exactly (e.g. categories, blog_author).
# MIGRATION_SHEET_WP_REST_PATHS=categories=/wp-json/wp/v2/story_category;blog_author=/wp-json/wp/v2/story_author
# MIGRATION_SHEET_CONTENT_TYPE_UID=categories=story_category;blog_author=blog_author
# Which tab from the workbook defines the content queue for migrate-content.
MIGRATION_START_SHEET=posts
MIGRATION_CONTENT_TYPE_UID=
MIGRATION_RUN_ID=stack-a
MIGRATION_ENV_LABEL=stack-a

# --- Tracking workbook (generated/updated by pipeline) ---
MIGRATION_TRACKING_WORKBOOK=migration-tracking.xlsx
MIGRATION_TRACKING_SHEET=migration_tracking

# --- Optional featured image (asset reference field UID on the Contentstack content type) ---
CS_FEATURED_IMAGE_FIELD_UID=

# --- Optional: custom CMA links in tracking / Mongo (default = Contentstack CMA GET URLs) ---
# CONTENTSTACK_ENTRY_TARGET_URL_TEMPLATE=https://{api_host}/v3/content_types/{content_type_uid}/entries/{entry_uid}?locale={locale}
# CONTENTSTACK_ASSET_TARGET_URL_TEMPLATE=https://{api_host}/v3/assets/{asset_uid}

# --- MongoDB (optional; omit MONGODB_URI to skip) ---
MONGODB_URI=
MONGODB_DB_NAME=
MONGODB_COLLECTION=migration_tracking

# --- Publish (Contentstack environment names in the stack) ---
CONTENTSTACK_PUBLISH_ENVIRONMENTS=production
CONTENTSTACK_PUBLISH_LOCALES=en-us
# PUBLISH_MODE=bulk-status
# PUBLISH_FILTER_MIGRATION_STATUS=Pass
# PUBLISH_FILTER_PUBLISH_STATUS=Unpublished
